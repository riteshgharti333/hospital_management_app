// GENERATOR CLIENT
generator client {
  provider = "prisma-client-js"
}

// DATABASE CONNECTION
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// USER MANAGEMENT
model User {
  id                 String    @id @default(uuid())
  regId              String    @unique
  name               String
  email              String    @unique

  role               Role      @default(DOCTOR)
  password           String

  mustChangePassword Boolean   @default(true)
  isActive           Boolean   @default(true)

  permissions        Json      @default("{}")

  resetToken         String?
  resetTokenExpiry   DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sessions           Session[]
  activityLogs       ActivityLog[]
}

// USER SESSIONS
model Session {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])

  refreshTokenHash  String
  ip                String?
  userAgent         String?

  createdAt         DateTime @default(now())
  expiresAt         DateTime
}

// USER ACTIVITY LOGS
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// USER ROLES
enum Role {
  ADMIN
  DOCTOR
  NURSE
}

// PATIENT MANAGEMENT
model Patient {
  id                 Int      @id @default(autoincrement())
  hospitalPatientId  String   @unique
  fullName           String
  dateOfBirth        DateTime
  gender             String
  mobileNumber       String?
  aadhaarNumber      String?  @unique
  address            String

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  admissions         Admission[]
}

// ADMISSION STATUS
enum AdmissionStatus {
  ACTIVE
  DISCHARGED
  CANCELLED
}

// ADMISSION MANAGEMENT
model Admission {
  id                   Int      @id @default(autoincrement())
  hospitalAdmissionId  String   @unique

  patientId            Int
  doctorId             Int

  admissionDate        DateTime
  dischargeDate        DateTime?
  status               AdmissionStatus @default(ACTIVE)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  patient              Patient  @relation(fields: [patientId], references: [id])
  doctor               Doctor   @relation(fields: [doctorId], references: [id])

  prescriptions        Prescription[]   

  @@index([patientId])
  @@index([doctorId])
  @@index([admissionDate])
}

// BIRTH RECORD MANAGEMENT
model Birth {
  id               Int      @id @default(autoincrement())
  birthTime        String
  birthDate        DateTime
  babySex          String
  babyWeightKg     Float
  fathersName      String
  mothersName      String
  mobileNumber     String
  deliveryType     String 
  placeOfBirth     String
  attendantsName   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([birthDate])
  @@index([mobileNumber])
  @@index([fathersName])
  @@index([mothersName])
  @@index([babySex])
}

// DOCTOR MANAGEMENT
model Doctor {
  id             Int      @id @default(autoincrement())
  fullName       String
  mobileNumber   String
  registrationNo String   @unique
  qualification  String
  designation    String
  email          String   @unique
  specialization String
  status         String   @default("Active")

  headedDepartment Department? @relation("DepartmentHead")
  appointments     Appointment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  admissions     Admission[]

  @@index([mobileNumber])
  @@index([status])
}

// DEPARTMENT MANAGEMENT
model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  status      DepartmentStatus @default(ACTIVE)

  headId      Int      @unique
  head        Doctor   @relation("DepartmentHead", fields: [headId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// DEPARTMENT STATUS
enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

// APPOINTMENT STATUS
enum AppointmentStatus {
  BOOKED
  CANCELLED
  EXPIRED
}

// APPOINTMENT MANAGEMENT
model Appointment {
  id              Int      @id @default(autoincrement())
  appointmentDate DateTime
  appointmentTime String

  status          AppointmentStatus @default(BOOKED)

  doctorId        Int
  doctor          Doctor   @relation(fields: [doctorId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([appointmentDate])
  @@index([doctorId])
}

// NURSE MANAGEMENT
model Nurse {
  id             Int      @id @default(autoincrement())
  fullName       String
  mobileNumber   String
  registrationNo String   @unique
  email          String   @unique
  department     String
  address        String
  shift          String
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([fullName])
  @@index([mobileNumber])
  @@index([registrationNo])
  @@index([status])
  @@index([shift])
  @@index([createdAt])
}

// PRESCRIPTION STATUS
enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// PRESCRIPTION MANAGEMENT
model Prescription {
  id               Int                 @id @default(autoincrement())
  admissionId      Int
  prescriptionNo   String              @unique

  prescriptionDate DateTime            @default(now())
  prescriptionDoc  String?
  notes            String?
  status           PrescriptionStatus  @default(ACTIVE)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  admission        Admission           @relation(fields: [admissionId], references: [id])
  medicines        Medicine[]

  @@index([admissionId])
  @@index([prescriptionNo])
}

// MEDICINE MANAGEMENT
model Medicine {
  id             Int       @id @default(autoincrement())
  prescriptionId Int

  medicineName   String
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

// LEDGER AMOUNT TYPES
enum AmountType {
  CREDIT
  DEBIT
}

// LEDGER ENTITY TYPES
enum EntityType {
  PATIENT
  DOCTOR
  BANK
  CASH
}

// LEDGER MANAGEMENT
model Ledger {
  id              Int      @id @default(autoincrement())
  code            String   @unique

  entityType      String  
  entityId        String

  transactionDate DateTime
  description     String

  amountType      AmountType
  amount          Decimal   @db.Decimal(12, 2)
  balance         Decimal   @db.Decimal(12, 2)

  paymentMode     PaymentMode?

  referenceType   String?
  referenceId     String?

  remarks         String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([entityType, entityId])
  @@index([transactionDate])
}

// CASH AMOUNT TYPES
enum CashAmountType {
  INCOME
  EXPENSE
}

// PAYMENT MODES
enum PaymentMode {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
}

// CASH ACCOUNT MANAGEMENT
model CashAccount {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  cashName  String   @db.VarChar(100)

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// BANK ACCOUNT MANAGEMENT
model BankAccount {
  id        Int      @id @default(autoincrement())
  code      String   @unique

  bankName  String   @db.VarChar(100)
  accountNo String   @db.VarChar(50)  @unique
  ifscCode  String?  @db.VarChar(20)

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bankName])
}

// BILL MANAGEMENT
model Bill {
  id             Int          @id @default(autoincrement())
  billDate       DateTime
  billType       String
  mobile         String
  admissionNo    String
  patientName    String
  admissionDate  DateTime
  patientSex     String
  dischargeDate  DateTime?
  totalAmount    Float
  address        String
  status         String       @default("Pending")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  billItems      BillItem[]
}

// BILL ITEMS MANAGEMENT
model BillItem {
  id             Int      @id @default(autoincrement())
  billId         Int
  bill           Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  company        String
  itemOrService  String
  quantity       Int
  mrp            Float  
  totalAmount    Float   
  createdAt      DateTime @default(now())
}

// MONEY RECEIPT MANAGEMENT
model MoneyReceipt {
  id           Int       @id @default(autoincrement())
  date         DateTime
  patientName  String
  mobile       String
  amount       Float
  paymentMode  String
  admissionNo  String
  remarks      String?
  receivedBy   String
  status       String    @default("Active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([mobile])
  @@index([patientName])
  @@index([amount])
  @@index([paymentMode])
}